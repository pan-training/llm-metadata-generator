# Required
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=sk-replace-me
SECRET_KEY=change-me-to-a-random-string

# Optional – defaults shown
DATABASE_URL=data/metadata.db
CRON_METADATA_INTERVAL=1440   # minutes between metadata refresh runs  (default: daily)
CRON_ONTOLOGY_INTERVAL=720    # hours between ontology index refreshes  (default: monthly)
CRON_TOOLS_INTERVAL=168       # hours between semantic-tool refreshes   (default: weekly)
