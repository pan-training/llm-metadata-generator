# Required
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=sk-replace-me
SECRET_KEY=change-me-to-a-random-string

# Optional – defaults shown
DATABASE_URL=data/metadata.db
CRON_METADATA_INTERVAL=1440   # minutes between metadata refresh runs  (default: daily)
CRON_METADATA_FULL_REFRESH_PROBABILITY=0.01  # chance of full refresh on a run (default: 1%)
CRON_ONTOLOGY_INTERVAL=720    # hours between ontology index refreshes  (default: monthly)
CRON_TOOLS_INTERVAL=168       # hours between semantic-tool refreshes   (default: weekly)

# LLM model selection (defaults target common LocalAI / open-source deployments)
LLM_MODEL_SMALL=qwen2.5-coder-7b-instruct   # fast model: content classification, link decisions
LLM_MODEL_LARGE=gemma-3-27b-it              # quality model: extraction, review, tool discovery
LLM_MODEL_EMBEDDING=qwen3-embedding-8b      # embedding model: ontology vector search (TODO #6)
